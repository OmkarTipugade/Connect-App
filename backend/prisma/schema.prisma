// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  username       String?
  phone          String?   @unique
  phoneSuffix    String?
  email          String?   @unique
  otp            String?
  otpExpiry      DateTime?
  emailOtp       String?
  emailOtpExpiry DateTime?
  profilePicture String?
  about          String    @default("")
  lastSeen       DateTime?
  agreed         Boolean   @default(false)
  isOnline       Boolean   @default(false)
  isVerified     Boolean?  @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // relations
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  conversations    Conversation[]
  reactions        Reaction[]
  Status           Status[]
  StatusView       StatusView[]
}

model Reaction {
  id        String     @id @default(cuid())
  emoji     String
  user      User    @relation(fields: [userId], references: [id])
  userId    String
  message   Message @relation(fields: [messageId], references: [id])
  messageId String
}

model Conversation {
  id      String    @id @default(cuid())
  members User[] // many-to-many relation

  lastMsg   Message? @relation("LastMessage", fields: [lastMsgId], references: [id])
  lastMsgId String?     @unique

  unreadCount Int @default(0)

  messages Message[] @relation("ConversationMessages") // all messages in this conversation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id String @id @default(cuid())

  conversation   Conversation @relation("ConversationMessages", fields: [conversationId], references: [id])
  conversationId String

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  senderId String

  receiver        User          @relation("ReceivedMessages", fields: [receiverId], references: [id])
  receiverId      String
  imageOrVideoUrl String?
  content         String?
  contentType     ContentType   @default(TEXT)
  messageStatus   MessageStatus @default(SENT)

  reactions Reaction[]

  lastMessageOf Conversation? @relation("LastMessage") 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Status {
  id           String        @id @default(cuid())
  user         User       @relation(fields: [userId], references: [id])
  userId       String        
  username     String?   
  profilePicture String?  
  url          String?
  content      String?
  contentType  ContentType @default(TEXT)
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  viewedBy     StatusView[]
}

model StatusView {
  id            String      @id @default(cuid())
  status        Status   @relation(fields: [statusId], references: [id])
  statusId      String
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  username      String?  
  profilePicture String? 
  viewedAt      DateTime @default(now())
}


enum ContentType {
  TEXT
  IMAGE
  VIDEO
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}
