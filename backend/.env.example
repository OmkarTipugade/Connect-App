# Backend environment variables
PORT=5000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5434/chat-app-project

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production

# CORS — frontend URL
FRONTEND_URL=http://localhost:5173

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email OTP (Gmail)
EMAIL_USER=
EMAIL_PASS=

# Twilio Verify (phone OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=
